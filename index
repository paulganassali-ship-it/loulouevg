<style>
/* ── Reset & vars ─────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --ink:     #0f0f0f;
  --paper:   #f4efe6;
  --cream:   #e8e2d8;
  --card:    #ffffff;
  --red:     #e8321a;
  --gold:    #f5a623;
  --teal:    #16a08a;
