}
.btn:active { transform: scale(.96); }
.btn:disabled { opacity: .4; cursor: not-allowed; }
.btn-red    { background: var(--red);  color: #fff; box-shadow: 0 4px 16px rgba(232,50,26,.3); }
.btn-ink    { background: var(--ink);  color: #fff; }
.btn-teal   { background: var(--teal); color: #fff; box-shadow: 0 4px 16px rgba(22,160,138,.25); }
.btn-gold   { background: var(--gold); color: var(--ink); }
