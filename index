}
input:focus, textarea:focus { border-color: var(--red); }
textarea { min-height: 88px; }
input.code-input {
  text-transform: uppercase;
  letter-spacing: .25em;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1.3rem;
  text-align: center;
}

/* ── Buttons ──────────────────────────────────────────────────────────── */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  border: none;
  border-radius: 13px;
  padding: 15px 20px;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: .92rem;
  cursor: pointer;
  transition: transform .12s, opacity .12s, box-shadow .12s;
