<!-- Firebase SDK -->
<script type="module">
import { initializeApp }           from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getDatabase, ref, set, get, update, push, onValue, off }
                                   from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

// ── helpers ──────────────────────────────────────────────────────────────────
const $ = id => document.getElementById(id);
const AVATARS = ["🦊","🐼","🦁","🐸","🐧","🦄","🐙","🦋","🐺","🦅","🐻","🦜"];
const COLORS  = ["#fde68a","#d1fae5","#dbeafe","#fce7f3","#ffe4e6","#e0e7ff","#fef3c7","#ecfdf5","#f0f9ff","#fdf4ff","#fff7ed","#f0fdf4"];

function avatar(name) {
  const i = Math.abs([...name].reduce((a,c)=>a+c.charCodeAt(0),0)) % AVATARS.length;
  return { emoji: AVATARS[i], color: COLORS[i] };
}
function uid() { return Math.random().toString(36).slice(2,10); }
function code4() { return Math.random().toString(36).slice(2,6).toUpperCase(); }
function shuffle(arr) {
  for (let i=arr.length-1;i>0;i--) {
    const j=Math.floor(Math.random()*(i+1));
    [arr[i],arr[j]]=[arr[j],arr[i]];
  }
  return arr;
}

const QUESTIONS = [
  "Quel est ton film préféré de tous les temps ?",
  "Si tu pouvais vivre dans n'importe quel pays, lequel choisirais-tu ?",
  "Quelle est la chose la plus bizarre que tu aies jamais mangée ?",
  "Quel superpouvoir voudrais-tu avoir et pourquoi ?",
  "Quel serait ton dernier repas si tu pouvais choisir n'importe quoi ?",
  "Quelle est ta peur secrète la plus honteuse ?",
  "Si tu pouvais dîner avec n'importe qui (vivant ou mort), qui choisirais-tu ?",
  "Quel est ton guilty pleasure inavouable ?",
  "Quelle célébrité ressembles-tu le plus selon toi ?",
  "Si tu étais un animal, lequel serais-tu et pourquoi ?",
  "Quelle est la chose la plus folle que tu aies faite ?",
  "Si tu gagnais 1 million d'euros demain, qu'est-ce que tu ferais en premier ?",
  "Quelle chanson tu écoutes en boucle en ce moment ?",
  "Quelle est ton application préférée sur ton téléphone ?",
  "Quel est ton souvenir d'enfance le plus drôle ?",
];

// ── State ─────────────────────────────────────────────────────────────────────
let db, gameRef, unsubscribe;
let state = {
  screen: "loading",   // loading | setup | home | lobby | answering | waiting | reveal | scores
  playerId: localStorage.getItem("qdc_pid") || uid(),
  playerName: localStorage.getItem("qdc_name") || "",
  gameCode: "",
  isHost: false,
  game: null,
  myVote: "",
  revealReady: false,
  showWho: false,
};
localStorage.setItem("qdc_pid", state.playerId);

// ── Firebase init ─────────────────────────────────────────────────────────────
function initFirebase() {
  try {
    if (FIREBASE_CONFIG.apiKey === "REMPLACE_PAR_TON_API_KEY") {
      state.screen = "setup";
      render();
      return false;
    }
    const app = initializeApp(FIREBASE_CONFIG);
    db = getDatabase(app);
    state.screen = "home";
    render();
    return true;
  } catch(e) {
    console.error(e);
    state.screen = "setup";
    render();
    return false;
  }
}

// ── Firebase game CRUD ────────────────────────────────────────────────────────
async function createGame(hostName, question) {
  const code = code4();
  const pid = state.playerId;
  const av = avatar(hostName);
  const gameData = {
    code,
    question: question || QUESTIONS[Math.floor(Math.random()*QUESTIONS.length)],
    phase: "lobby",
    hostId: pid,
    revealIndex: 0,
    players: {
      [pid]: { id: pid, name: hostName, emoji: av.emoji, color: av.color, score: 0 }
    },
    answers: {},
    createdAt: Date.now(),
  };
  await set(ref(db, `games/${code}`), gameData);
  return code;
}

async function joinGame(code, name) {
  const snap = await get(ref(db, `games/${code}`));
  if (!snap.exists()) return "Partie introuvable — vérifie le code.";
  const g = snap.val();
  if (g.phase !== "lobby") return "La partie a déjà commencé.";
  const players = g.players || {};
  if (Object.keys(players).length >= 8) return "Partie pleine (8 joueurs max).";
  const nameTaken = Object.values(players).some(p => p.name.toLowerCase() === name.toLowerCase());
  if (nameTaken) return "Ce prénom est déjà pris dans cette partie.";
  const pid = state.playerId;
  const av = avatar(name);
  await update(ref(db, `games/${code}/players/${pid}`), {
    id: pid, name, emoji: av.emoji, color: av.color, score: 0
  });
  return null; // no error
}

function subscribeGame(code) {
  if (unsubscribe) { off(ref(db, `games/${code}`)); }
  const r = ref(db, `games/${code}`);
  onValue(r, snap => {
    if (!snap.exists()) return;
    state.game = snap.val();
    syncScreen();
    render();
  });
  unsubscribe = () => off(r);
}

function syncScreen() {
  const g = state.game;
  if (!g) return;
  const phase = g.phase;
  const myAnswered = g.answers && g.answers[state.playerId];

  if (phase === "lobby")    state.screen = "lobby";
  else if (phase === "answering") {
    state.screen = myAnswered ? "waiting" : "answering";
  }
  else if (phase === "reveal")  state.screen = "reveal";
  else if (phase === "scores")  state.screen = "scores";
}

// ── Render engine ─────────────────────────────────────────────────────────────
function render() {
  const app = document.getElementById("app");
  switch(state.screen) {
    case "loading":   app.innerHTML = `<div class="spinner"></div>`; break;
    case "setup":     app.innerHTML = renderSetup(); break;
    case "home":      app.innerHTML = renderHome(); break;
    case "lobby":     app.innerHTML = renderLobby(); break;
    case "answering": app.innerHTML = renderAnswering(); break;
    case "waiting":   app.innerHTML = renderWaiting(); break;
    case "reveal":    app.innerHTML = renderReveal(); break;
    case "scores":    app.innerHTML = renderScores(); break;
  }
  bindEvents();
}

// ── Screen: Setup ─────────────────────────────────────────────────────────────
function renderSetup() {
  return `
  ${logo()}
  <div class="setup-box">
    <strong>🔧 Configuration requise — 15 minutes, c'est gratuit !</strong>
    <ol>
      <li><span class="step-chip">1</span>Va sur <strong>console.firebase.google.com</strong> → "Créer un projet"</li>
      <li><span class="step-chip">2</span>Dans ton projet → <strong>Realtime Database</strong> → "Créer une base de données" → choisir "Mode test" (pour commencer)</li>
      <li><span class="step-chip">3</span>⚙️ Paramètres du projet → "Tes applications" → Ajoute une app Web → copie le bloc <code>firebaseConfig</code></li>
      <li><span class="step-chip">4</span>Ouvre ce fichier HTML dans un éditeur texte → remplace le bloc <code>FIREBASE_CONFIG</code> en haut par tes clés</li>
      <li><span class="step-chip">5</span>Dépose le fichier sur <strong>Netlify Drop</strong> (<code>app.netlify.com/drop</code>) — ton jeu est en ligne instantanément !</li>
    </ol>
    <div style="margin-top:10px;color:#888;font-size:.78rem;">
      💡 Envoie juste le lien Netlify à tes amis, ils peuvent jouer depuis leur téléphone sans rien installer.
    </div>
  </div>`;
}

// ── Screen: Home ──────────────────────────────────────────────────────────────
function renderHome() {
  return `
  ${logo()}
  <div class="card">
    <div class="card-title">Bienvenue !</div>
    <span class="label">Ton prénom</span>
    <input id="inp-name" placeholder="Ex: Marie" value="${esc(state.playerName)}" maxlength="20"/>
    <div id="home-error" class="error" style="display:none"></div>
    <button class="btn btn-red" id="btn-create">✨ Créer une partie</button>
    <button class="btn btn-ink mt" id="btn-go-join">🎟 Rejoindre avec un code</button>
  </div>

  <div class="card mt" id="join-section" style="display:none; max-width:440px; width:100%;">
    <div class="card-title">Rejoindre une partie</div>
    <span class="label">Code de la partie</span>
    <input id="inp-code" class="code-input" placeholder="A3K9" maxlength="4"/>
    <button class="btn btn-ink" id="btn-join">Rejoindre →</button>
    <div id="join-error" class="error" style="display:none"></div>
  </div>`;
}

// ── Screen: Lobby ─────────────────────────────────────────────────────────────
function renderLobby() {
  const g = state.game;
  if (!g) return `<div class="spinner"></div>`;
  const players = Object.values(g.players || {});
  const isHost = g.hostId === state.playerId;
  return `
  ${logo()}
  <div class="card">
    <span class="label">Code de la partie</span>
    <div class="code-display">
      <div class="big-code">${g.code}</div>
      <div class="hint">Partage ce code avec tes amis 📱</div>
    </div>
    <div class="q-box">💬 ${esc(g.question)}</div>
    <span class="label">Joueurs (${players.length}/8)</span>
    <ul class="player-list">
      ${players.map(p=>`
        <li class="player-row">
          <div class="ava" style="background:${p.color}">${p.emoji}</div>
          <span>${esc(p.name)}</span>
          ${p.id===state.playerId?`<span class="you-badge">toi</span>`:""}
          ${p.id===g.hostId?`<span class="host-badge">Hôte</span>`:""}
        </li>`).join("")}
    </ul>
    <div id="lobby-error" class="error" style="display:none"></div>
    ${isHost
      ? `<button class="btn btn-red mt" id="btn-start" ${players.length<2?"disabled":""}>
           ${players.length<2?"En attente d'un autre joueur…":"🎮 Lancer la partie !"}</button>`
      : `<p class="waiting">⏳ En attente que l'hôte lance la partie…</p>`
    }
    <button class="btn btn-ghost mt" id="btn-leave">Quitter</button>
  </div>`;
}

// ── Screen: Answering ─────────────────────────────────────────────────────────
function renderAnswering() {
  const g = state.game;
  return `
  ${logo()}
  <div class="card">
    <div class="card-title">Réponds anonymement ✍️</div>
    <div class="q-box">?