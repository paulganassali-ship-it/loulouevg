/* ── Progress dots ────────────────────────────────────────────────────── */
.dots { display:flex; gap:6px; justify-content:center; margin: 12px 0; }
.dot { width:10px; height:10px; border-radius:50%; background:var(--cream); transition:background .3s; }
.dot.done    { background: var(--teal); }
.dot.pending { background: var(--cream); }

/* ── Reveal card ──────────────────────────────────────────────────────── */
.reveal-wrap {
  background: var(--ink);
  border-radius: var(--r);
  padding: 26px 20px;
  margin: 14px 0;
  animation: popIn .4s cubic-bezier(.22,1,.36,1);
}
@keyframes popIn {
  from { opacity:0; transform:scale(.85) translateY(8px); }
  to   { opacity:1; transform:scale(1) translateY(0); }
}
.reveal-answer {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.2rem, 4.5vw, 1.65rem);
  font-weight: 700;
  color: #fff;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 20px;
}
.vote-label { font-size: .75rem; color: #aaa; text-align:center; margin-bottom: 10px; letter-spacing:.08em; text-transform:uppercase; }
.vote-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.vote-btn {
  border: 2px solid rgba(255,255,255,.15);
  background: rgba(255,255,255,.07);
  color: #fff;
  border-radius: 11px;
  padding: 10px 10px;
  font-family: 'DM Sans', sans-serif;
  font-size: .85rem;
  cursor: pointer;
  transition: background .15s, border-color .15s, transform .1s;
  text-align: left;
}
.vote-btn:hover  { background: rgba(255,255,255,.16); border-color:rgba(255,255,255,.4); }
.vote-btn:active { transform: scale(.95); }
.vote-btn.selected { background: var(--blue); border-color: var(--blue); }
.vote-btn.correct  { background: var(--teal); border-color: var(--teal); }
.vote-btn.wrong    { background: #8B0000; border-color: #8B0000; opacity:.65; }

/* ── Who said it ──────────────────────────────────────────────────────── */
.who-revealed {
  text-align: center;
  animation: popIn .4s cubic-bezier(.22,1,.36,1);
}
.who-emoji { font-size: 2.8rem; display:block; margin-bottom:6px; }
.who-name  { font-family:'Syne',sans-serif; font-weight:800; font-size:1.5rem; color:#fff; }
.result-msg { font-size:.9rem; margin-top: 8px; }
.correct-msg { color: var(--gold); font-weight:700; }
.wrong-msg   { color: #aaa; }

/* ── Scoreboard ───────────────────────────────────────────────────────── */
.score-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 0;
  border-bottom: 1px solid var(--cream);
}
.score-row:last-child { border-bottom: none; }
.rank { font-family:'Syne',sans-serif; font-weight:800; font-size:1.5rem; color:var(--red); width:28px; flex-shrink:0; }
.pts  { margin-left:auto; font-family:'Syne',sans-serif; font-weight:700; font-size:1.1rem; color:var(--teal); }

/* ── Utility ──────────────────────────────────────────────────────────── */
.divider   { border:none; border-top:2px solid var(--cream); margin:14px 0; }
.error     { color:var(--red); font-size:.82rem; margin: -8px 0 8px; }
.info      { color:#888; font-size:.82rem; text-align:center; margin: 8px 0; }
.center    { text-align: center; }
.mt        { margin-top: 10px; }
.waiting   { color:#888; font-size:.88rem; text-align:center; padding:10px 0; }

/* ── Spinner ──────────────────────────────────────────────────────────── */
.spinner {
  width:36px; height:36px;
  border:3px solid var(--cream);
  border-top-color:var(--red);
  border-radius:50%;
  animation: spin .7s linear infinite;
  margin: 24px auto;
}
@keyframes spin { to { transform:rotate(360deg); } }

/* ── Setup screen ─────────────────────────────────────────────────────── */
.setup-box {
  background: #fffbe6;
  border: 1.5px solid var(--gold);
  border-radius: 14px;
  padding: 18px;
  font-size: .83rem;
  line-height: 1.7;
  max-width: 440px;
  width: 100%;
  margin-bottom: 20px;
}
.setup-box strong { font-weight:700; }
.setup-box code {
