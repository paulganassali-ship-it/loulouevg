  font-size: .68rem;
  background: var(--cream);
  color: #777;
  padding: 2px 8px;
  border-radius: 99px;
}

/* ── Question box ─────────────────────────────────────────────────────── */
.q-box {
  border-left: 4px solid var(--red);
  background: var(--paper);
  border-radius: 0 10px 10px 0;
  padding: 12px 14px;
  font-size: 1rem;
  font-weight: 500;
  line-height: 1.5;
  margin-bottom: 16px;
